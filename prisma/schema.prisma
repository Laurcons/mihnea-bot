generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../data/sqlite.db"
}

model WordleResult {
  id        Int      @id @default(autoincrement())
  userId    String
  username  String
  loggedAt  DateTime
  gameType  String
  puzzleDay Int
  tries     Int?
  maxTries  Int
  attempts  String // JSON-encoded string[]
  createdAt DateTime @default(now())

  @@unique([userId, gameType, puzzleDay])
}
